DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DATABASE
# Vercel's Supabase integration may provide these instead of DATABASE_URL.
# The CMS will prefer DATABASE_URL, then DATABASE_POSTGRES_URL_NON_POOLING, then DATABASE_POSTGRES_URL.
DATABASE_POSTGRES_URL_NON_POOLING=
DATABASE_POSTGRES_URL=
# For local seeding against providers with self-signed cert chains only:
# DATABASE_SSL_REJECT_UNAUTHORIZED=false
PAYLOAD_SECRET=replace-with-a-long-random-secret
NEXT_PUBLIC_SITE_URL=http://localhost:3000
BLOB_READ_WRITE_TOKEN=
