---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Button from '../components/Button.astro';
import BookOnlineButton from '../components/BookOnlineButton.astro';
import Drop from '../components/Drop.astro';
import ImagePlaceholder from '../components/ImagePlaceholder.astro';
import CtaBand from '../components/CtaBand.astro';
import { getServices, getSiteContent } from '../lib/cms';

const { site } = await getSiteContent();
const services = await getServices();
---

<BaseLayout
  title="Our Services"
  description="Drain cleaning, water heaters, whole-home filtration, leak detection, and residential plumbing across Tampa Bay."
>
  <PageHero
    eyebrow="Our services"
    title="Everything plumbing. Everything water."
    description="Eight ways we keep Tampa Bay homes flowing — every one backed by upfront pricing and our workmanship guarantee."
  />

  <nav aria-label="Jump to a service" class="border-b border-line bg-mist">
    <ul class="mx-auto flex max-w-7xl flex-wrap justify-center gap-2 px-4 py-5 sm:px-6 lg:px-8">
      {
        services.map((service) => (
          <li>
            <a
              href={`#${service.id}`}
              class="inline-flex min-h-[44px] items-center rounded-full px-4 py-1.5 text-sm font-semibold text-ink/60 transition hover:bg-mist hover:text-ink focus:outline-none focus-visible:ring-2 focus-visible:ring-water"
            >
              {service.title}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>

  <div class="mx-auto max-w-7xl space-y-24 px-4 py-20 sm:px-6 lg:px-8">
    {
      services.map((service, i) => (
        <section
          id={service.id}
          aria-labelledby={`${service.id}-title`}
          class="grid scroll-mt-28 items-center gap-10 lg:grid-cols-2"
        >
          <div class={i % 2 === 1 ? 'lg:order-2' : ''}>
            <Drop color={service.accent} size="lg" />
            <h2
              id={`${service.id}-title`}
              class="mt-5 font-heading text-3xl font-extrabold tracking-tight text-ink"
            >
              {service.title}
            </h2>
            <p class="mt-4 text-lg leading-relaxed text-ink/60">{service.blurb}</p>
            <ul class="mt-6 grid gap-3 sm:grid-cols-2">
              {service.bullets.map((bullet) => (
                <li class="flex items-center gap-3 text-ink/75">
                  <Drop size="sm" color={service.accent} />
                  {bullet}
                </li>
              ))}
            </ul>
            <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-4">
              <BookOnlineButton>Book Online</BookOnlineButton>
              <Button href={site.phoneHref} variant="outline" class="text-brand-red">
                Call {site.phone}
              </Button>
              <a
                href={`/services/${service.slug}`}
                class="inline-flex min-h-[44px] items-center gap-2 rounded-btn font-heading font-bold text-ink/80 transition-all hover:gap-3 hover:text-ink focus:outline-none focus-visible:ring-2 focus-visible:ring-water"
              >
                Explore this service
                <span aria-hidden="true">→</span>
              </a>
            </div>
          </div>
          {
            service.detailImageUrl ? (
              <img
                src={service.detailImageUrl}
                alt={service.title}
                loading="lazy"
                class={`aspect-[4/3] w-full rounded-panel object-cover shadow-card ${i % 2 === 1 ? 'lg:order-1' : ''}`}
              />
            ) : (
              <ImagePlaceholder
                label={`Photo: ${service.title}`}
                class={`aspect-[4/3] w-full ${i % 2 === 1 ? 'lg:order-1' : ''}`}
              />
            )
          }
        </section>
      ))
    }
  </div>

  <CtaBand
    title="Not sure which service you need?"
    description="Describe the problem and we'll point you in the right direction — no jargon, no pressure."
  />
</BaseLayout>
