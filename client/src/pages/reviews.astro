---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import ReviewCard from '../components/ReviewCard.astro';
import Stars from '../components/Stars.astro';
import CtaBand from '../components/CtaBand.astro';
import { getReviews, getRatingSummary } from '../lib/reviews';
import { getPageHeadline } from '../lib/cms';

const reviews = await getReviews();
const ratingSummary = await getRatingSummary();

const headline = await getPageHeadline('reviews', {
  eyebrow: 'Reviews',
  title: "Don't take our word for it.",
  description:
    'Real reviews from real neighbors across Hillsborough, Polk, Pasco, Pinellas, and Marion counties. Spin through them below.',
});
---

<BaseLayout
  title="Reviews"
  description="Read what Tampa Bay homeowners say about our plumbing and water filtration work — a perfect 5.0 average rating."
>
  <PageHero {...headline} />

  <section class="overflow-hidden py-20" aria-label="Customer reviews">
    <div
      class="mx-auto mb-4 flex max-w-md flex-col items-center gap-2 rounded-panel border border-line bg-mist px-8 py-6 text-center"
    >
      <p class="font-heading text-5xl font-extrabold text-ink">{ratingSummary.average}</p>
      <Stars />
      <p class="text-ink/60">
        Based on {ratingSummary.count} verified {ratingSummary.source}
      </p>
    </div>

    <div
      id="review-carousel"
      aria-roledescription="carousel"
      aria-label="Review carousel — use the previous and next buttons or arrow keys to browse"
    >
      <div id="review-stage" class="review-stage">
        {
          reviews.map((review, i) => (
            <div class="review-slide" data-index={i}>
              <ReviewCard review={review} />
            </div>
          ))
        }
      </div>

      <div class="mt-2 flex items-center justify-center gap-6">
        <button type="button" id="review-prev" class="carousel-btn" aria-label="Previous review">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path
              d="M12.5 4L6.5 10L12.5 16"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </button>
        <p class="min-w-20 text-center font-heading font-bold tabular-nums text-ink/70">
          <span id="review-counter">1</span>
          <span class="text-ink/40">/ {reviews.length}</span>
        </p>
        <button type="button" id="review-next" class="carousel-btn" aria-label="Next review">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path
              d="M7.5 4L13.5 10L7.5 16"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </button>
      </div>
    </div>
  </section>

  <CtaBand
    title="Ready to become our next 5-star review?"
    description="Book online or give us a call — we'll earn it."
  />
</BaseLayout>

<style>
  .review-stage {
    position: relative;
    height: 460px;
    perspective: 1500px;
    cursor: grab;
    touch-action: pan-y;
    user-select: none;
    -webkit-user-select: none;
  }

  .review-stage.dragging {
    cursor: grabbing;
  }

  .review-slide {
    position: absolute;
    left: 50%;
    top: 50%;
    width: min(86vw, 400px);
    height: 420px;
    will-change: transform, opacity;
    transition:
      transform 0.5s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.5s ease;
  }

  .review-stage.dragging .review-slide {
    transition: none;
  }

  /* Long reviews: clamp inside the fixed-height card. */
  .review-slide :global(figure) {
    height: 100%;
  }

  .review-slide :global(blockquote) {
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 8;
    overflow: hidden;
  }

  .carousel-btn {
    display: grid;
    place-items: center;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    border: 2px solid currentColor;
    color: #e8232f;
    transition:
      transform 0.15s ease,
      opacity 0.15s ease;
  }

  .carousel-btn:hover {
    transform: scale(1.08);
  }

  .carousel-btn:active {
    transform: scale(0.96);
  }

  @media (prefers-reduced-motion: reduce) {
    .review-slide {
      transition: none;
    }
  }
</style>

<script>
  const stage = document.getElementById('review-stage');
  const counter = document.getElementById('review-counter');
  const prevBtn = document.getElementById('review-prev');
  const nextBtn = document.getElementById('review-next');

  if (stage && counter && prevBtn && nextBtn) {
    const slides = Array.from(stage.querySelectorAll<HTMLElement>('.review-slide'));
    const n = slides.length;
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    let current = 0; // fractional while dragging
    let spacing = 340;

    // Shortest signed circular distance from the active slide.
    const offsetOf = (i: number) => ((((i - current) % n) + n * 1.5) % n) - n / 2;

    // How many slides on each side of the active one stay mounted. Slides
    // past this are hidden with `display: none` so iOS Safari doesn't allocate
    // a GPU compositing layer (from `will-change`) for every one of the ~230+
    // reviews at once — that layer explosion is what crashed the page.
    const WINDOW = 3;

    const render = () => {
      for (const [i, slide] of slides.entries()) {
        const d = offsetOf(i);
        const abs = Math.abs(d);
        if (abs > WINDOW) {
          slide.style.display = 'none';
          continue;
        }
        slide.style.display = '';
        slide.style.transform =
          `translate(-50%, -50%) translateX(${d * spacing}px) ` +
          `translateZ(${-abs * 160}px) rotateY(${d * -30}deg)`;
        slide.style.opacity = String(abs > 2.6 ? 0 : 1 - abs * 0.18);
        slide.style.zIndex = String(Math.round(100 - abs * 10));
        slide.style.pointerEvents = abs < 0.5 ? 'auto' : 'none';
      }
      counter.textContent = String(((Math.round(current) % n) + n) % n + 1);
    };

    const measure = () => {
      spacing = Math.min(360, stage.clientWidth * 0.34);
      render();
    };
    measure();
    window.addEventListener('resize', measure);

    const snapTo = (target: number) => {
      current = target;
      render();
    };

    // Autoplay until the visitor takes over.
    let autoplay: ReturnType<typeof setInterval> | undefined;
    const stopAutoplay = () => {
      if (autoplay) clearInterval(autoplay);
      autoplay = undefined;
    };
    if (!reducedMotion && n > 1) {
      autoplay = setInterval(() => snapTo(Math.round(current) + 1), 5000);
    }

    prevBtn.addEventListener('click', () => {
      stopAutoplay();
      snapTo(Math.round(current) - 1);
    });
    nextBtn.addEventListener('click', () => {
      stopAutoplay();
      snapTo(Math.round(current) + 1);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key !== 'ArrowLeft' && e.key !== 'ArrowRight') return;
      const rect = stage.getBoundingClientRect();
      if (rect.bottom < 0 || rect.top > window.innerHeight) return;
      stopAutoplay();
      snapTo(Math.round(current) + (e.key === 'ArrowRight' ? 1 : -1));
    });

    // Drag / swipe: the ring follows the pointer, then snaps.
    stage.addEventListener('pointerdown', (e) => {
      e.preventDefault();
      stopAutoplay();
      const startX = e.clientX;
      const startCurrent = current;
      let moved = false;

      stage.setPointerCapture(e.pointerId);
      stage.classList.add('dragging');

      const onMove = (ev: PointerEvent) => {
        const dx = ev.clientX - startX;
        if (Math.abs(dx) > 4) moved = true;
        current = startCurrent - dx / spacing;
        render();
      };

      const onUp = (ev: PointerEvent) => {
        stage.classList.remove('dragging');
        stage.removeEventListener('pointermove', onMove);
        stage.removeEventListener('pointerup', onUp);
        stage.removeEventListener('pointercancel', onUp);
        // Tiny drags snap back; real drags snap to the nearest card,
        // always moving at least one step in the drag direction.
        const dx = ev.clientX - startX;
        if (!moved) {
          snapTo(Math.round(startCurrent));
        } else if (Math.abs(dx) < spacing * 0.25) {
          snapTo(Math.round(startCurrent) + (dx < 0 ? 1 : -1));
        } else {
          snapTo(Math.round(current));
        }
      };

      stage.addEventListener('pointermove', onMove);
      stage.addEventListener('pointerup', onUp);
      stage.addEventListener('pointercancel', onUp);
    });
  }
</script>
