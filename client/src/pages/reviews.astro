---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import ReviewCard from '../components/ReviewCard.astro';
import Stars from '../components/Stars.astro';
import CtaBand from '../components/CtaBand.astro';
import { getReviews, getRatingSummary } from '../lib/reviews';

const reviews = await getReviews();
const ratingSummary = await getRatingSummary();

const INITIAL_COUNT = 24;
---

<BaseLayout
  title="Reviews"
  description="Read what Tampa Bay homeowners say about our plumbing and water filtration work — a perfect 5.0 average rating."
>
  <PageHero
    eyebrow="Reviews"
    title="Don't take our word for it."
    description="Real reviews from real neighbors across Hillsborough, Polk, Pasco, Pinellas, and Marion counties."
  />

  <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8" aria-label="Customer reviews">
    <div
      class="mx-auto mb-14 flex max-w-md flex-col items-center gap-2 rounded-panel border border-line bg-mist px-8 py-6 text-center"
    >
      <p class="font-heading text-5xl font-extrabold text-ink">{ratingSummary.average}</p>
      <Stars />
      <p class="text-ink/60">
        Based on {ratingSummary.count} verified {ratingSummary.source}
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3" data-reviews-grid>
      {
        reviews.map((review, index) => (
          <div class:list={['h-full', { hidden: index >= INITIAL_COUNT }]}>
            <ReviewCard review={review} />
          </div>
        ))
      }
    </div>

    {
      reviews.length > INITIAL_COUNT && (
        <div class="mt-12 text-center">
          <button
            type="button"
            data-show-more
            class="inline-flex min-h-[44px] items-center justify-center gap-2 rounded-full border-2 border-current px-8 py-3.5 font-heading font-bold uppercase tracking-wide text-brand-red transition hover:opacity-80 focus:outline-none focus-visible:ring-2 focus-visible:ring-water"
          >
            Show more reviews
          </button>
        </div>
      )
    }
  </section>

  <CtaBand
    title="Ready to become our next 5-star review?"
    description="Book online or give us a call — we'll earn it."
  />
</BaseLayout>

<script>
  const grid = document.querySelector('[data-reviews-grid]');
  const button = document.querySelector<HTMLButtonElement>('[data-show-more]');

  if (grid && button) {
    const BATCH = 24;
    button.addEventListener('click', () => {
      const hidden = grid.querySelectorAll('.hidden');
      for (const el of Array.from(hidden).slice(0, BATCH)) {
        el.classList.remove('hidden');
      }
      if (hidden.length <= BATCH) button.parentElement?.remove();
    });
  }
</script>
