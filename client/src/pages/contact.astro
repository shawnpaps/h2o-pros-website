---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Button from '../components/Button.astro';
import Drop from '../components/Drop.astro';
import { getSiteContent } from '../lib/cms';

const { site, hours } = await getSiteContent();

const serviceOptions = [
  'Drain Cleaning & Hydro-Jetting',
  'Water Heater Services',
  'Whole-Home Filtration & RO',
  'Leak Detection & Pipe Repair',
  'General / Residential Plumbing',
  'Something else',
];

const inputClasses =
  'w-full rounded-btn border border-line bg-white px-4 py-3 text-ink placeholder:text-ink/40 focus:border-water focus:outline-none focus:ring-2 focus:ring-water/30';
---

<BaseLayout
  title="Contact"
  description="Book online or call (813) 702-1118. Serving five counties across Tampa Bay."
>
  <PageHero
    eyebrow="Contact"
    title="Let's get your water sorted."
    description="Fill out the form and we'll get right back to you — or skip the typing and call during business hours."
  />

  <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
    <div class="grid gap-12 lg:grid-cols-[1fr_minmax(0,1.4fr)]">
      <!-- Contact info -->
      <div class="space-y-8">
        <div class="rounded-panel border border-line bg-mist p-7">
          <h2 class="flex items-center gap-3 font-heading text-lg font-extrabold text-ink">
            <Drop color="red" /> Call or text
          </h2>
          <a
            href={site.phoneHref}
            class="mt-3 inline-flex min-h-[44px] items-center rounded-btn font-heading text-3xl font-extrabold text-brand-red hover:text-brand-red-dark focus:outline-none focus-visible:ring-2 focus-visible:ring-water"
          >
            {site.phone}
          </a>
          <p class="mt-1 text-ink/60">A real person answers during business hours.</p>
        </div>

        <div class="rounded-panel border border-line bg-mist p-7">
          <h2 class="flex items-center gap-3 font-heading text-lg font-extrabold text-ink">
            <Drop /> Email
          </h2>
          <a
            href={site.emailHref}
            class="mt-3 inline-flex min-h-[44px] items-center break-all rounded-btn font-semibold text-water hover:text-ink focus:outline-none focus-visible:ring-2 focus-visible:ring-water"
          >
            {site.email}
          </a>
          <p class="mt-1 text-ink/60">We reply within one business day.</p>
        </div>

        <div class="rounded-panel border border-line bg-mist p-7">
          <h2 class="flex items-center gap-3 font-heading text-lg font-extrabold text-ink">
            <Drop /> Hours
          </h2>
          <ul class="mt-4 space-y-2">
            {
              hours.map((h) => (
                <li class="flex items-baseline justify-between gap-4 text-ink/70">
                  <span>{h.label}</span>
                  <span class="font-semibold text-ink">{h.value}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <!-- Booking form -->
      <form
        class="rounded-panel border border-line bg-white p-7 shadow-soft sm:p-10"
        method="POST"
        action="#"
      >
        <h2 class="font-heading text-2xl font-extrabold text-ink">Book online</h2>
        <p class="mt-2 text-ink/60">
          Tell us what's going on and we'll confirm a time — usually within the hour during
          business hours.
        </p>

        <div class="mt-8 grid gap-5 sm:grid-cols-2">
          <div>
            <label for="name" class="mb-1.5 block font-semibold text-ink">Full name</label>
            <input id="name" name="name" type="text" required autocomplete="name" class={inputClasses} />
          </div>
          <div>
            <label for="phone" class="mb-1.5 block font-semibold text-ink">Phone</label>
            <input id="phone" name="phone" type="tel" required autocomplete="tel" class={inputClasses} />
          </div>
          <div class="sm:col-span-2">
            <label for="email" class="mb-1.5 block font-semibold text-ink">Email</label>
            <input id="email" name="email" type="email" required autocomplete="email" class={inputClasses} />
          </div>
          <div class="sm:col-span-2">
            <label for="address" class="mb-1.5 block font-semibold text-ink">
              Service address <span class="font-normal text-ink/50">(city & county help too)</span>
            </label>
            <input id="address" name="address" type="text" autocomplete="street-address" class={inputClasses} />
          </div>
          <div class="sm:col-span-2">
            <label for="service" class="mb-1.5 block font-semibold text-ink">What do you need?</label>
            <select id="service" name="service" class={inputClasses}>
              {serviceOptions.map((option) => <option value={option}>{option}</option>)}
            </select>
          </div>
          <div class="sm:col-span-2">
            <label for="message" class="mb-1.5 block font-semibold text-ink">Tell us more</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              class={inputClasses}
              placeholder="Slow drain in the hall bath, water heater making noise, curious about filtration…"
            ></textarea>
          </div>
        </div>

        <div class="mt-8">
          <Button type="submit" size="lg" class="w-full sm:w-auto">Request my appointment</Button>
          <p class="mt-4 text-sm text-ink/50">
            Prefer to talk it through? <a href={site.phoneHref} class="font-bold text-brand-red underline-offset-4 hover:underline">
              Call {site.phone}</a
            > during business hours.
          </p>
        </div>
      </form>
    </div>
  </section>
</BaseLayout>
