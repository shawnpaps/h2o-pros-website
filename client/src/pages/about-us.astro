---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Button from '../components/Button.astro';
import Drop from '../components/Drop.astro';
import CtaBand from '../components/CtaBand.astro';
import { Image } from 'astro:assets';
import teamPhotoImage from '../assets/team-photo.jpg';
import tampaServiceAreaImage from '../assets/tampa-service-area.jpg';
import { getSiteContent, getSiteSettings } from '../lib/cms';

const { site, counties } = await getSiteContent();
const settings = await getSiteSettings();

const values = [
  {
    title: 'Honest, upfront pricing',
    text: 'You approve the exact price before we touch a wrench. The quote never changes mid-job.',
  },
  {
    title: 'Treat every home like ours',
    text: 'Shoe covers on, drop cloths down, and the work area cleaner than we found it.',
  },
  {
    title: 'Fix it right, once',
    text: 'We diagnose the root cause instead of patching symptoms — and guarantee the workmanship.',
  },
  {
    title: 'Actually friendly',
    text: 'It’s in the name. A real person answers the phone and a real neighbor shows up.',
  },
];

const offers = [
  {
    title: 'Free Whole-Home Water Test',
    detail: 'In-home testing for hardness, chlorine, and more — with zero-pressure results.',
    fine: 'No purchase necessary. Ever.',
  },
  {
    title: '$75 Off Any Water Heater Install',
    detail: 'Tank or tankless — mention this offer when you book.',
    fine: 'One per household. Cannot combine with other offers.',
  },
  {
    title: '10% Senior, Military & First-Responder Discount',
    detail: 'Our thank-you to the folks who look after everyone else.',
    fine: 'Applies to labor on any standard service.',
  },
];
---

<BaseLayout
  title="About Us"
  description="Meet Your Friendly Neighborhood H2O Pros — licensed, insured, and proudly serving five counties across Tampa Bay."
>
  <PageHero
    eyebrow="About us"
    title="Your friendly neighborhood pros."
    description="Locally owned, fully licensed, and built on the belief that calling a plumber shouldn't ruin your day."
  />

  <!-- Story -->
  <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8" aria-labelledby="story-title">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <div>
        <SectionHeading
          id="story-title"
          eyebrow="Our story"
          title="Plumbing with a handshake."
          align="left"
        />
        <div class="mt-6 space-y-4 text-lg leading-relaxed text-ink/65">
          <p>
            Your Friendly Neighborhood H2O Pros started with a simple frustration: too many
            homeowners getting vague quotes, muddy boot prints, and repairs that didn't stick. We
            decided Tampa Bay deserved better.
          </p>
          <p>
            Today we're a fully licensed and insured team (License {site.license}) handling
            everything from stubborn drain clogs to whole-home filtration systems — always with
            upfront pricing, tidy workmanship, and a genuine smile.
          </p>
        </div>
        <div class="mt-8">
          <Button href="/contact">Get to know us — book a visit</Button>
        </div>
      </div>
      {
        settings.teamPhotoUrl ? (
          <img
            src={settings.teamPhotoUrl}
            alt="H2O Pros team"
            loading="lazy"
            class="aspect-[4/3] w-full rounded-panel object-cover shadow-card"
          />
        ) : (
          <Image
            src={teamPhotoImage}
            alt="The H2O Pros team standing in front of their branded plumbing van"
            width={1280}
            loading="lazy"
            class="aspect-[4/3] w-full rounded-panel object-cover shadow-card"
          />
        )
      }
    </div>
  </section>

  <!-- Values -->
  <section class="bg-mist" aria-labelledby="values-title">
    <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
      <SectionHeading id="values-title" eyebrow="What we stand for" title="Four promises, every visit." />
      <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          values.map((value) => (
            <div class="rounded-panel border border-line bg-fog p-7 shadow-card">
              <Drop size="md" />
              <h3 class="mt-4 font-heading text-lg font-extrabold text-ink">{value.title}</h3>
              <p class="mt-2 leading-relaxed text-ink/60">{value.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Current offers -->
  <section
    id="CurrentOffersandSavings"
    class="mx-auto max-w-7xl scroll-mt-28 px-4 py-20 sm:px-6 lg:px-8"
    aria-labelledby="offers-title"
  >
    <SectionHeading
      id="offers-title"
      eyebrow="Current offers & savings"
      title="A little something for your wallet."
      description="Mention any of these when you book — no coupon clipping required."
    />
    <div class="mt-14 grid gap-6 md:grid-cols-3">
      {
        offers.map((offer) => (
          <div class="flex flex-col rounded-panel border-2 border-dashed border-brand-red/30 bg-fog p-7">
            <p class="font-heading text-xl font-extrabold text-brand-red">{offer.title}</p>
            <p class="mt-3 flex-1 leading-relaxed text-ink/65">{offer.detail}</p>
            <p class="mt-4 border-t border-line pt-4 text-sm text-ink/45">{offer.fine}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Service area -->
  <section id="OurServiceArea" class="scroll-mt-28 bg-mist" aria-labelledby="area-title">
    <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
      <div class="grid items-center gap-12 lg:grid-cols-2">
        {
          settings.serviceAreaMapUrl ? (
            <img
              src={settings.serviceAreaMapUrl}
              alt="Service area map"
              loading="lazy"
              class="aspect-[4/3] w-full rounded-panel object-cover shadow-card"
            />
          ) : (
            <Image
              src={tampaServiceAreaImage}
              alt="Downtown Tampa skyline reflected on the waterfront at dusk"
              width={1280}
              loading="lazy"
              class="aspect-[4/3] w-full rounded-panel object-cover shadow-card"
            />
          )
        }
        <div>
          <SectionHeading
            id="area-title"
            eyebrow="Our service area"
            title="Five counties. One phone number."
            description="From downtown Tampa to Ocala horse country, we cover the whole neighborhood."
            align="left"
          />
          <ul class="mt-8 flex flex-wrap gap-3">
            {
              counties.map((county) => (
                <li class="inline-flex items-center gap-2 rounded-full border border-line bg-fog px-5 py-2.5 font-semibold text-ink/70 shadow-card">
                  <Drop size="sm" />
                  {county} County
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </section>

  <CtaBand />
</BaseLayout>
