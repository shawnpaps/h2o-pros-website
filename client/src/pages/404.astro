---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
	title="Page Not Found"
	description="The page you're looking for doesn't exist."
	headerVariant="dark"
	noindex
>
	<section class="flex min-h-[60vh] flex-col items-center justify-center gap-6 px-6 text-center">
		<p class="text-sm font-semibold uppercase tracking-widest text-water">404</p>
		<h1 class="text-4xl font-bold">Page not found</h1>
		<p class="max-w-md text-lg opacity-80">
			The page you're looking for doesn't exist or may have moved.
		</p>
		<a
			href="/"
			class="rounded-full bg-water px-6 py-3 font-semibold text-white transition hover:opacity-90"
		>
			Back to home
		</a>
	</section>
</BaseLayout>
