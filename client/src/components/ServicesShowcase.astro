---
/**
 * Editorial split-screen services showcase: full-bleed photo on the left,
 * spec-sheet panel on the right, and a giant title straddling the seam —
 * solid over the photo, outlined over the panel. A horizontal selector bar
 * along the bottom switches the active service (tabs pattern). Auto-rotates
 * until the visitor interacts; respects prefers-reduced-motion.
 */
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import BookOnlineButton from './BookOnlineButton.astro';
import drainImage from '../assets/services/samuel-sianipar-scUBcasSvbE-unsplash.jpg';
import heaterImage from '../assets/services/waterheater.jpg';
import filtrationImage from '../assets/services/timur-shakerzianov-c314Gh8dXAo-unsplash.jpg';
import leakImage from '../assets/services/pan-xiaozhen-IYE0ImQlY90-unsplash.jpg';
import { getServices, getSiteContent } from '../lib/cms';
import cardBackground from '../assets/graphics/webs.png';

/** Fallback panel image per featured service, used when the CMS has none. */
const fallbackImages: Record<string, ImageMetadata> = {
	DrainandSewer: drainImage,
	WaterHeater: heaterImage,
	Filtration: filtrationImage,
	LeakDetection: leakImage,
};

const [services, { site }] = await Promise.all([
	getServices(),
	getSiteContent(),
]);
const featuredServices = services.filter((service) => service.featured);

const items = featuredServices.map((service, i) => ({
	...service,
	index: String(i + 1).padStart(2, '0'),
	image: fallbackImages[service.id] ?? drainImage,
	imageUrl: service.showcaseImageUrl,
	displayName: service.showcaseTitle || service.title,
	badge: service.showcaseBadge,
}));

const total = String(items.length).padStart(2, '0');
---

<section
	class="relative overflow-hidden bg-mist"
	aria-labelledby="services-title"
	data-svc-root
>
	<h2 id="services-title" class="sr-only">What we do — featured services</h2>

	<div class="relative grid lg:min-h-[44rem] lg:grid-cols-[45fr_55fr]">
		<!-- Photo side -->
		<div
			class="relative aspect-[4/3] overflow-hidden bg-ink-deep sm:aspect-[16/9] lg:aspect-auto"
		>
			{
				items.map((item, i) => (
					<div
						class="svc-fade absolute inset-0"
						data-svc-layer
						data-active={i === 0 ? '' : undefined}
						aria-hidden="true">
						{item.imageUrl ? (
							<img
								src={item.imageUrl}
								alt=""
								loading={i === 0 ? 'eager' : 'lazy'}
								class="h-full w-full object-cover"
							/>
						) : (
							<Image
								src={item.image}
								alt=""
								width={1280}
								class="h-full w-full object-cover"
							/>
						)}
						<div
							class="absolute inset-0 bg-gradient-to-t from-ink-deep/80 via-ink-deep/10 to-ink-deep/40"
							aria-hidden="true"
						/>
					</div>
				))
			}

			<!-- Mobile title (desktop uses the split title below) -->
			<div
				class="absolute inset-x-0 bottom-0 grid p-6 sm:p-10 lg:hidden"
				aria-hidden="true"
			>
				{
					items.map((item, i) => (
						<p
							class="svc-fade col-start-1 row-start-1 font-heading text-4xl font-extrabold uppercase leading-none tracking-tight text-ink sm:text-5xl"
							data-svc-title-m
							data-active={i === 0 ? '' : undefined}>
							{item.displayName}
						</p>
					))
				}
			</div>
		</div>

		<!-- Spec-sheet panel -->
		<div class="relative px-6 pb-16 pt-12 sm:px-10 lg:px-16 lg:pb-20 lg:pt-72">
			<Image
				src={cardBackground}
				alt=""
				aria-hidden="true"
				class="absolute inset-x-0 top-0 w-full h-full blur-lg object-cover"
			/>
			<div class="grid">
				{
					items.map((item, i) => (
						<div
							class="svc-fade col-start-1 row-start-1 flex flex-col bg-white/10 backdrop-blur-2xl rounded-panel p-6 sm:p-10 lg:p-16 z-10"
							role="tabpanel"
							id={`svc-panel-${item.id}`}
							aria-labelledby={`svc-tab-${item.id}`}
							data-svc-panel
							data-active={i === 0 ? '' : undefined}>
							<h3 class="sr-only">{item.title}</h3>

							<div class="grid gap-3 border-t border-line pt-6 sm:grid-cols-[8rem_1fr] sm:gap-8">
								<p class="font-mono text-[0.65rem] font-bold uppercase tracking-[0.25em] text-ink/45">
									Your Friendly Neighborhood Solution:
								</p>
								<p class="max-w-xl leading-relaxed text-ink/75">{item.blurb}</p>
							</div>

							<div class="mt-10 grid gap-3 border-t border-line pt-6 sm:grid-cols-[8rem_1fr] sm:gap-8">
								<p class="font-mono text-[0.65rem] font-bold uppercase tracking-[0.25em] text-ink/45">
									Services Include:
								</p>
								<ul class="flex max-w-xl flex-wrap gap-x-2 gap-y-2.5 font-heading text-xs font-bold uppercase tracking-wide text-ink/85">
									{item.bullets.map((bullet) => (
										<li class="after:pl-0.5 after:text-ink/30 after:content-[','] last:after:content-none">
											{bullet}
										</li>
									))}
								</ul>
							</div>

							{item.badge && (
								<p class="mt-10 font-heading text-sm font-extrabold uppercase tracking-wide text-water-light">
									→ {item.badge}
								</p>
							)}

							<div class="mt-10 flex flex-wrap items-center gap-x-6 gap-y-4">
								<BookOnlineButton>Book Online</BookOnlineButton>
								<a
									href={`/services/${item.slug}`}
									class="inline-flex min-h-[44px] items-center gap-2 rounded-btn font-heading font-bold text-ink/80 transition-all hover:gap-3 hover:text-ink focus:outline-none focus-visible:ring-2 focus-visible:ring-water">
									Full details
									<span aria-hidden="true">→</span>
								</a>
							</div>
						</div>
					))
				}
			</div>

			<p
				class="mt-14 text-right font-mono text-xs tracking-[0.25em] text-ink/40"
				aria-hidden="true"
			>
				<span data-svc-counter>01</span>
				<span class="px-1">//</span>
				{total}
			</p>
		</div>

		<!-- Split title straddling the seam (desktop only) -->
		<div
			class="pointer-events-none absolute inset-x-0 top-24 z-10 hidden lg:block"
			aria-hidden="true"
		>
			<div class="grid grid-cols-[minmax(0,1fr)]">
				{
					items.map((item, i) => (
						<div
							class="svc-fade col-start-1 row-start-1 min-w-0"
							data-svc-title
							data-active={i === 0 ? '' : undefined}>
							<div class="relative" data-svc-title-box>
								<p class="svc-title-half svc-title-solid whitespace-nowrap pl-[14%] pr-[4%] font-heading text-[clamp(3.5rem,7vw,7rem)] font-extrabold uppercase leading-none tracking-tight">
									{item.displayName}
								</p>
								<p class="svc-title-half svc-title-hollow absolute inset-0 whitespace-nowrap pl-[14%] pr-[4%] font-heading text-[clamp(3.5rem,7vw,7rem)] font-extrabold uppercase leading-none tracking-tight">
									{item.displayName}
								</p>
							</div>
						</div>
					))
				}
			</div>
		</div>
	</div>

	<!-- Horizontal service selector -->
	<div class="border-t border-line bg-ink-deep">
		<div
			class="flex overflow-x-auto"
			role="tablist"
			aria-label="Featured services"
		>
			{
				items.map((item, i) => (
					<button
						type="button"
						role="tab"
						id={`svc-tab-${item.id}`}
						aria-selected={i === 0 ? 'true' : 'false'}
						aria-controls={`svc-panel-${item.id}`}
						tabindex={i === 0 ? 0 : -1}
						class="group relative min-w-[11rem] flex-1 border-r border-line px-6 py-5 text-left transition last:border-r-0 hover:bg-white/5 focus:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-water"
						data-svc-btn
						data-active={i === 0 ? '' : undefined}>
						<span class="block font-mono text-[0.65rem] tracking-[0.25em] text-ink/35 transition group-data-[active]:text-water-light">
							{item.index}
						</span>
						<span class="mt-1.5 block font-heading text-sm font-extrabold uppercase tracking-wide text-ink/45 transition group-hover:text-ink/75 group-data-[active]:text-ink">
							{item.displayName}
						</span>
						<span class="svc-progress" data-svc-progress aria-hidden="true" />
					</button>
				))
			}
		</div>
	</div>
</section>

<style>
	/* Crossfading layers: images, titles, and spec panels all share this.
	   visibility keeps links/buttons in hidden panels out of the tab order. */
	.svc-fade {
		opacity: 0;
		visibility: hidden;
		transition:
			opacity 0.55s ease,
			visibility 0.55s;
	}
	.svc-fade[data-active] {
		opacity: 1;
		visibility: visible;
	}

	/* Two-tone straddling title: the solid copy shows over the photo (left
	   45% of the section), the hollow copy over the panel. Negative vertical
	   insets keep ascenders/descenders from being clipped. */
	.svc-title-solid {
		color: #e9eef5;
		clip-path: inset(-25% 55% -25% -5%);
	}
	.svc-title-hollow {
		color: transparent;
		-webkit-text-stroke: 2px rgba(233, 238, 245, 0.55);
		clip-path: inset(-25% -5% -25% 45%);
	}

	/* Auto-rotate progress bar (only while [data-autoplay] is set by JS) */
	.svc-progress {
		position: absolute;
		inset-inline: 0;
		bottom: 0;
		height: 3px;
		width: 0%;
		background: linear-gradient(90deg, #3d7bee, #8fb5fa, #e8232f);
	}
	[data-svc-root][data-autoplay] [data-svc-btn][data-active] .svc-progress {
		animation: svc-fill 7s linear forwards;
	}
	[data-svc-root][data-autoplay]:hover .svc-progress,
	[data-svc-root][data-autoplay]:focus-within .svc-progress {
		animation-play-state: paused;
	}
	@keyframes svc-fill {
		from {
			width: 0%;
		}
		to {
			width: 100%;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.svc-fade {
			transition: none;
		}
		.svc-progress {
			animation: none !important;
		}
	}
</style>

<script>
	const root = document.querySelector('[data-svc-root]');
	if (root) {
		const buttons = Array.from(
			root.querySelectorAll<HTMLButtonElement>('[data-svc-btn]'),
		);
		const fadeGroups = [
			Array.from(root.querySelectorAll('[data-svc-layer]')),
			Array.from(root.querySelectorAll('[data-svc-title]')),
			Array.from(root.querySelectorAll('[data-svc-title-m]')),
			Array.from(root.querySelectorAll('[data-svc-panel]')),
		];
		const counters = Array.from(root.querySelectorAll('[data-svc-counter]'));
		const titleBoxes = Array.from(
			root.querySelectorAll<HTMLElement>('[data-svc-title-box]'),
		);

		// Titles come from the CMS, so any of them can be too long for the
		// nowrap split title. Shrink the font just enough to fit the seam width.
		const fitTitles = () => {
			titleBoxes.forEach((box) => {
				const halves = Array.from(
					box.querySelectorAll<HTMLElement>('.svc-title-half'),
				);
				const solid = halves[0];
				if (!solid) return;
				halves.forEach((el) => (el.style.fontSize = ''));
				if (!box.clientWidth) return; // hidden below lg
				const overflow = solid.scrollWidth - solid.clientWidth;
				if (overflow <= 0) return;
				const style = getComputedStyle(solid);
				const padding =
					parseFloat(style.paddingLeft) + parseFloat(style.paddingRight);
				const textWidth = solid.scrollWidth - padding;
				const available = solid.clientWidth - padding;
				const size = Math.floor(
					parseFloat(style.fontSize) * (available / textWidth),
				);
				halves.forEach((el) => (el.style.fontSize = `${size}px`));
			});
		};

		fitTitles();
		window.addEventListener('resize', fitTitles);
		document.fonts?.ready.then(fitTitles);
		const reducedMotion = window.matchMedia(
			'(prefers-reduced-motion: reduce)',
		).matches;
		let current = 0;

		const activate = (index: number, fromUser: boolean) => {
			current = index;
			fadeGroups.forEach((group) =>
				group.forEach((el, i) =>
					i === index
						? el.setAttribute('data-active', '')
						: el.removeAttribute('data-active'),
				),
			);
			buttons.forEach((btn, i) => {
				const active = i === index;
				btn.setAttribute('aria-selected', String(active));
				btn.tabIndex = active ? 0 : -1;
				if (active) btn.setAttribute('data-active', '');
				else btn.removeAttribute('data-active');
			});
			counters.forEach((el) => {
				el.textContent = String(index + 1).padStart(2, '0');
			});
			// First interaction hands control to the visitor for good.
			if (fromUser) root.removeAttribute('data-autoplay');
		};

		buttons.forEach((btn, i) => {
			btn.addEventListener('click', () => activate(i, true));
			btn.addEventListener('keydown', (e) => {
				if (e.key !== 'ArrowRight' && e.key !== 'ArrowLeft') return;
				e.preventDefault();
				const dir = e.key === 'ArrowRight' ? 1 : -1;
				const next = (i + dir + buttons.length) % buttons.length;
				activate(next, true);
				buttons[next].focus();
			});
		});

		// The CSS progress bar finishing is the auto-advance signal.
		root.addEventListener('animationend', (e) => {
			if (
				e.target instanceof Element &&
				e.target.hasAttribute('data-svc-progress')
			) {
				activate((current + 1) % buttons.length, false);
			}
		});

		const observer = new IntersectionObserver(
			([entry]) => {
				if (!entry.isIntersecting) return;
				if (!reducedMotion) root.setAttribute('data-autoplay', '');
				observer.disconnect();
			},
			{ threshold: 0.2 },
		);
		observer.observe(root);
	}
</script>
