---
const { site, ratingSummary } = Astro.props;
import Button from './Button.astro';
import Stars from './Stars.astro';
import Drop from './Drop.astro';
import heroVideo from '../assets/videos/hero.mp4';

const heroServices = [
	{
		title: 'Water Heater Replacements',
		blurb:
			'Tank or tankless — we size the unit to your home, install it clean, and haul the old one away. Reliable hot water, guaranteed.',
		href: '/our-services#WaterHeater',
		accent: 'red',
	},
	{
		title: 'Water Filtration & Treatment',
		blurb:
			'Free in-home water testing, whole-home carbon filtration, softeners, and reverse-osmosis systems tailored to Tampa Bay water.',
		href: '/our-services#Filtration',
		accent: 'blue',
	},
	{
		title: 'Hydro-Jetting',
		blurb:
			'High-pressure jetting scours grease, scale, and roots out of your sewer lines — restoring pipes to like-new flow.',
		href: '/our-services#DrainandSewer',
		accent: 'blue',
	},
] as const;
---

<section class="relative min-h-screen overflow-hidden bg-ink-deep text-white">
	<video
		src={heroVideo}
		class="absolute inset-0 h-full w-full object-cover"
		autoplay
		muted
		loop
		playsinline
	>
	</video>
	<div
		class="absolute inset-0 bg-gradient-to-r from-ink-deep/70 via-ink-deep/30 to-ink-deep/50"
		aria-hidden="true"
	>
	</div>
	<div
		class="relative z-10 mx-auto flex max-w-7xl flex-col items-center gap-6 px-4 py-36 text-center sm:px-6 lg:px-8"
	>
		<h1 class="text-7xl max-w-3xl mt-8 font-heading text-white drop-shadow-lg">
			We are your friendly, neighborhood plumbing experts
		</h1>
	</div>
</section>
