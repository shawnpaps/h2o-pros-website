---
const { site, ratingSummary } = Astro.props;
import Button from './Button.astro';
import Stars from './Stars.astro';
import Drop from './Drop.astro';
import heroVideo from '../assets/videos/hero.mp4';
import { getSiteSettings } from '../lib/cms';

const settings = await getSiteSettings();

const heroServices = [
	{
		title: 'Water Heater Replacements',
		blurb:
			'Tank or tankless — we size the unit to your home, install it clean, and haul the old one away. Reliable hot water, guaranteed.',
		href: '/our-services#WaterHeater',
		accent: 'red',
	},
	{
		title: 'Water Filtration & Treatment',
		blurb:
			'Free in-home water testing, whole-home carbon filtration, softeners, and reverse-osmosis systems tailored to Tampa Bay water.',
		href: '/our-services#Filtration',
		accent: 'blue',
	},
	{
		title: 'Hydro-Jetting',
		blurb:
			'High-pressure jetting scours grease, scale, and roots out of your sewer lines — restoring pipes to like-new flow.',
		href: '/our-services#DrainandSewer',
		accent: 'blue',
	},
] as const;
---

{/*
	Scroll-pinned hero: the sticky viewport holds the screen while vertical
	scrolling slides the cards horizontally, so every card is read before the
	page continues. The script stretches the section to create the scroll
	runway; without JS (or with reduced motion) it stays one screen tall and
	the cards scroll natively sideways.
*/}
<section class="relative bg-ink-deep text-white" data-hero>
	<div
		class="sticky top-0 flex h-screen flex-col justify-center overflow-hidden"
	>
		<video
			src={settings.homeHeroVideoUrl ?? heroVideo}
			class="absolute inset-0 h-full w-full object-cover"
			autoplay
			muted
			loop
			playsinline></video>
		<div
			class="absolute inset-0 bg-gradient-to-b from-ink-deep/60 via-ink-deep/20 to-ink-deep/60"
			aria-hidden="true"
		>
		</div>

		<div class="relative z-10 w-full overflow-x-auto py-10" data-hero-scroller>
			<div
				class="flex w-max items-stretch gap-6 px-6 will-change-transform sm:px-10"
				data-hero-track
			>
				{/* Company card */}
				<article
					class="z-10 flex w-[min(88vw,30rem)] shrink-0 flex-col justify-between rounded-panel border border-white/15 bg-white/50 p-8 shadow-lift backdrop-blur-2xl sm:p-10"
				>
					<div>
						<h1 class="font-heading text-3xl font-extrabold sm:text-4xl">
							{site.name}
							<span class="text-water-light">Plumbing</span>
						</h1>
						<p class="mt-4 text-lg text-white/80">
							Your trusted local plumbing & water filtration experts in Tampa
							Bay.
						</p>
					</div>
					<div>
						<div class="mt-8 flex flex-col gap-3 sm:flex-row">
							<Button href="/contact" variant="primary">Request Service</Button>
							<Button href="/our-services" variant="outline" class="text-white">
								View Services
							</Button>
						</div>
						<div class="mt-6 flex items-center gap-3">
							<Stars rating={Number(ratingSummary.average)} />
							<p class="text-sm font-medium text-white/80">
								{ratingSummary.average} · {ratingSummary.count}
								{ratingSummary.source}
							</p>
						</div>
					</div>
				</article>

				{/* Service cards */}
				{
					heroServices.map((service) => (
						<article class="flex w-[min(80vw,24rem)] shrink-0 flex-col rounded-panel border border-white/15 bg-white/10 p-8 shadow-lift backdrop-blur-2xl">
							<Drop color={service.accent} size="lg" />
							<h2 class="mt-5 font-heading text-2xl font-extrabold">
								{service.title}
							</h2>
							<p class="mt-3 leading-relaxed text-white/70">{service.blurb}</p>
							<a
								href={service.href}
								class="mt-auto inline-flex min-h-[44px] items-center gap-2 pt-6 font-heading font-bold text-water-light transition hover:gap-3 focus:outline-none focus-visible:ring-2 focus-visible:ring-water">
								Learn more
								<span aria-hidden="true">→</span>
							</a>
						</article>
					))
				}
			</div>
		</div>
	</div>
</section>

<script>
	const section = document.querySelector<HTMLElement>('[data-hero]');
	const scroller = document.querySelector<HTMLElement>('[data-hero-scroller]');
	const track = document.querySelector<HTMLElement>('[data-hero-track]');

	if (section && scroller && track) {
		const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
		// Page scroll distance per px of horizontal card travel. Higher = the
		// hero stays pinned longer, giving more reading time per card.
		const SCROLL_PER_PX = 2;

		let travel = 0;

		// Stretch the section to create the pinned scroll runway. If the cards
		// already fit on screen (very wide viewports) or the visitor prefers
		// reduced motion, fall back to a single-screen hero with native
		// horizontal scrolling.
		const measure = () => {
			travel = Math.max(0, track.scrollWidth - scroller.clientWidth);
			const pinned = travel > 0 && !reducedMotion.matches;
			section.style.height = pinned
				? `${window.innerHeight + travel * SCROLL_PER_PX}px`
				: '';
			scroller.classList.toggle('overflow-hidden', pinned);
			scroller.classList.toggle('overflow-x-auto', !pinned);
			if (!pinned) track.style.transform = '';
		};
		measure();
		window.addEventListener('resize', measure);
		reducedMotion.addEventListener('change', measure);

		const progressFor = (x: number) =>
			(section.offsetHeight - window.innerHeight) * (x / travel);

		// Tabbing into an off-screen card makes the browser scroll the hidden
		// overflow sideways. Undo that and jump the page to the scroll position
		// that reveals the focused card instead.
		scroller.addEventListener('focusin', (e) => {
			if (!scroller.classList.contains('overflow-hidden')) return;
			scroller.scrollLeft = 0;
			const card = (e.target as HTMLElement).closest('article');
			if (!card) return;
			const right = card.offsetLeft + card.offsetWidth;
			const x = Math.min(Math.max(right - scroller.clientWidth + 24, 0), travel);
			const sectionTop = section.getBoundingClientRect().top + window.scrollY;
			window.scrollTo({ top: sectionTop + progressFor(x) });
		});
		scroller.addEventListener('scroll', () => {
			if (scroller.classList.contains('overflow-hidden')) {
				scroller.scrollLeft = 0;
			}
		});

		let current = 0;
		let last = performance.now();

		const frame = (now: number) => {
			const dt = Math.min((now - last) / 1000, 0.1);
			last = now;

			if (travel > 0 && !reducedMotion.matches) {
				const range = section.offsetHeight - window.innerHeight;
				const y = Math.min(
					Math.max(-section.getBoundingClientRect().top, 0),
					range,
				);
				const target = range > 0 ? (y / range) * travel : 0;
				// Small lerp keeps the motion silky without lagging the scroll.
				current += (target - current) * Math.min(1, dt * 10);
				if (Math.abs(target - current) < 0.5) current = target;
				track.style.transform = `translate3d(${-current}px, 0, 0)`;
			}

			requestAnimationFrame(frame);
		};
		requestAnimationFrame(frame);
	}
</script>
