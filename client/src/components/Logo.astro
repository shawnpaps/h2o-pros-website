---
import logo from '../assets/logos/h2o-logo.webp';
import { getSiteContent } from '../lib/cms';

interface Props {
	tone?: 'light' | 'dark';
}

const { tone = 'light' } = Astro.props;
const { site, logoUrl } = await getSiteContent();
const wordColor = tone === 'dark' ? 'text-white' : 'text-ink';
const subColor = tone === 'dark' ? 'text-white/60' : 'text-ink/50';
---

<a
	href="/"
	class="inline-flex items-center gap-3 rounded-btn focus:outline-none focus-visible:ring-2 focus-visible:ring-water"
	aria-label={`${site.shortName} — home`}
>
	<img
		src={logoUrl ?? logo.src}
		width={logo.width}
		height={logo.height}
		alt=""
		class="h-20 w-auto"
	/>
	<span class={`font-heading text-lg font-extrabold ${wordColor}`}>
		Your Friendly Neighborhood H20 Pros
		<span class={`block text-sm font-normal ${subColor}`}>
			Plumbing & Water Filtration
		</span>
	</span>
</a>
