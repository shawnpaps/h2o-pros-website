---
interface Props {
  href?: string;
  variant?: 'primary' | 'outline' | 'ghost';
  size?: 'md' | 'lg';
  class?: string;
  type?: 'button' | 'submit';
}

const {
  href,
  variant = 'primary',
  size = 'md',
  class: className = '',
  type = 'button',
} = Astro.props;

const base =
  'inline-flex min-h-[44px] items-center justify-center gap-2 rounded-btn font-heading font-bold uppercase tracking-wide transition focus:outline-none focus-visible:ring-2 focus-visible:ring-water focus-visible:ring-offset-2';

const variants: Record<string, string> = {
  primary:
    'bg-brand-red text-white shadow-card hover:bg-brand-red-dark focus-visible:ring-offset-transparent',
  outline: 'border-2 border-current bg-transparent hover:opacity-80',
  ghost: 'bg-transparent hover:bg-ink/5',
};

const sizes: Record<string, string> = {
  md: 'px-6 py-2.5 text-sm',
  lg: 'px-8 py-3.5 text-base',
};

const classes = `${base} ${variants[variant]} ${sizes[size]} ${className}`;
---

{
  href ? (
    <a href={href} class={classes}>
      <slot />
    </a>
  ) : (
    <button type={type} class={classes}>
      <slot />
    </button>
  )
}
