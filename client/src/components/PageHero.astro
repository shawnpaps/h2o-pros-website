---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<section class="border-b border-line bg-mist">
  <div class="mx-auto max-w-7xl px-4 py-16 text-center sm:px-6 sm:py-20 lg:px-8">
    <p class="font-heading text-sm font-bold uppercase tracking-[0.2em] text-brand-red">
      {eyebrow}
    </p>
    <h1 class="mt-3 font-heading text-4xl font-extrabold tracking-tight text-ink sm:text-5xl">
      {title}
    </h1>
    {
      description && (
        <p class="mx-auto mt-5 max-w-2xl text-lg leading-relaxed text-ink/60">{description}</p>
      )
    }
  </div>
</section>
