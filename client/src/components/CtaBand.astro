---
import Button from './Button.astro';
import BookOnlineButton from './BookOnlineButton.astro';
import { getSiteContent } from '../lib/cms';

interface Props {
  title?: string;
  description?: string;
}

const { site, cta } = await getSiteContent();
// Pages can override the wording per-page; otherwise fall back to the
// site-wide Call-to-Action Band text edited in the CMS.
const { title = cta.title, description = cta.description } = Astro.props;
---

<section class="bg-brand-red" aria-labelledby="cta-band-title">
  <div
    class="mx-auto flex max-w-7xl flex-col items-center gap-8 px-4 py-16 text-center sm:px-6 lg:flex-row lg:justify-between lg:text-left lg:px-8"
  >
    <div class="max-w-2xl">
      <h2 id="cta-band-title" class="font-heading text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
        {title}
      </h2>
      <p class="mt-3 text-lg text-white/80">{description}</p>
    </div>
    <div class="flex flex-col gap-4 sm:flex-row">
      <BookOnlineButton
        size="lg"
        class="!bg-white !text-brand-red hover:!bg-white/90 focus-visible:!ring-white"
      >
        Book Online
      </BookOnlineButton>
      <Button href={site.phoneHref} variant="outline" size="lg" class="text-white">
        Call {site.phone}
      </Button>
    </div>
  </div>
</section>
