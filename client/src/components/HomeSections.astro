---
/**
 * Everything below the hero on the home page — shared verbatim by the
 * city landing pages under /locations/.
 */
import Drop from './Drop.astro';
import SectionHeading from './SectionHeading.astro';
import FaqItem from './FaqItem.astro';
import ReviewsSpotlight from './ReviewsSpotlight.astro';
import CtaBand from './CtaBand.astro';
import ServicesShowcase from './ServicesShowcase.astro';
import { Image } from 'astro:assets';
import tampaServiceAreaImage from '../assets/tampa-service-area.jpg';
import {
	getCounties,
	getFaqs,
	getSiteContent,
	getSiteSettings,
} from '../lib/cms';

const { site } = await getSiteContent();
const settings = await getSiteSettings();
const faqs = await getFaqs();

// Derived from the Locations collection — each chip links to its county page.
const counties = await getCounties();
const countWords = [
	'zero',
	'one',
	'two',
	'three',
	'four',
	'five',
	'six',
	'seven',
	'eight',
	'nine',
	'ten',
	'eleven',
	'twelve',
];
const countyCountWord = countWords[counties.length] ?? String(counties.length);

const trustStats = [
	{ value: site.license, label: 'Licensed, insured & bonded' },
	{ value: '8-5', label: 'Monday-Friday service' },
	{ value: `${counties.length} counties`, label: 'Across Tampa Bay' },
	{ value: 'Upfront', label: 'Flat-rate pricing' },
];

const whyStats = [
	{ value: '5.0★', label: 'Average rating from real neighbors' },
	{ value: 'Family', label: 'Owned and operated' },
	{ value: '100%', label: 'Workmanship guaranteed' },
	{ value: 'Flat Rate', label: 'Pricing — you approve before we start' },
];
---

<!-- Trust strip (overlaps hero) --><!-- Services -->
<ServicesShowcase />

<!-- Why choose us -->
<section class="bg-ink-deep" aria-labelledby="why-title">
	<div class="mx-auto max-w-7xl px-4 py-24 sm:px-6 lg:px-8">
		<SectionHeading
			id="why-title"
			eyebrow="Why choose us"
			title="Neighbors first, plumbers second."
			description="We're more than just plumbers. We're your trusted partners for a safer, healthier home. Founded on the principles of integrity, expertise, and a genuine commitment to our community, we've built a reputation for delivering reliable, high-quality plumbing and water filtration services. We understand that your home's plumbing is the heart of its comfort and safety, and we treat every job, big or small, with the attention and care it deserves."
			tone="dark"
		/>
		<div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
			{
				whyStats.map((stat) => (
					<div class="rounded-panel border border-white/20 bg-white/10 p-8 text-center backdrop-blur">
						<p class="font-heading text-3xl font-extrabold text-water-light">
							{stat.value}
						</p>
						<p class="mt-2 leading-relaxed text-white/65">{stat.label}</p>
					</div>
				))
			}
		</div>
	</div>
</section>

<!-- Reviews -->
<ReviewsSpotlight />

<!-- Service area -->
<section
	class="mx-auto max-w-7xl px-4 py-24 sm:px-6 lg:px-8"
	aria-labelledby="area-title"
>
	<div class="grid items-center gap-12 lg:grid-cols-2">
		<div>
			<SectionHeading
				id="area-title"
				eyebrow="Service area"
				title={`Proudly serving Tampa Bay and beyond.`}
				description="If you're in the greater Tampa Bay area, chances are we're already in your neighborhood."
				align="left"
			/>
			<ul class="mt-8 flex flex-wrap gap-3">
				{
					counties.map((county) => (
						<li>
							<a
								href={`/counties/${county.slug}`}
								class="inline-flex items-center gap-2 rounded-full border border-line bg-mist px-5 py-2.5 font-semibold text-ink/70 transition hover:border-water hover:text-water"
							>
								<Drop size="sm" />
								{county.name} County
							</a>
						</li>
					))
				}
			</ul>
			<p class="mt-8 text-ink/60">
				On the edge of the map? <a
					href={site.phoneHref}
					class="font-bold text-brand-red underline-offset-4 hover:underline"
					>Call us</a
				> — we'll do our best to get to you.
			</p>
		</div>
		{
			settings.serviceAreaMapUrl ? (
				<img
					src={settings.serviceAreaMapUrl}
					alt="Service area map"
					loading="lazy"
					class="aspect-[4/3] w-full rounded-panel object-cover shadow-card"
				/>
			) : (
				<Image
					src={tampaServiceAreaImage}
					alt="Downtown Tampa skyline reflected on the waterfront at dusk"
					width={1280}
					loading="lazy"
					class="aspect-[4/3] w-full rounded-panel object-cover shadow-card"
				/>
			)
		}
	</div>
</section>

<CtaBand />

<!-- FAQ -->
<section
	class="mx-auto max-w-3xl px-4 py-24 sm:px-6"
	aria-labelledby="faq-title"
>
	<SectionHeading
		id="faq-title"
		eyebrow="FAQ"
		title="Good questions, straight answers."
	/>
	<div class="mt-12 space-y-4">
		{faqs.map((faq) => <FaqItem question={faq.question} answer={faq.answer} />)}
	</div>
</section>
