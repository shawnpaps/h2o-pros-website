---
/**
 * Everything below the hero on the home page — shared verbatim by the
 * city landing pages under /locations/.
 */
import Button from './Button.astro';
import Drop from './Drop.astro';
import SectionHeading from './SectionHeading.astro';
import FaqItem from './FaqItem.astro';
import ReviewCard from './ReviewCard.astro';
import CtaBand from './CtaBand.astro';
import ServicesShowcase from './ServicesShowcase.astro';
import { Image } from 'astro:assets';
import tampaServiceAreaImage from '../assets/tampa-service-area.jpg';
import { getReviews, getRatingSummary } from '../lib/reviews';
import { getFaqs, getSiteContent, getSiteSettings } from '../lib/cms';

const { site, counties } = await getSiteContent();
const settings = await getSiteSettings();
const reviews = await getReviews();
const ratingSummary = await getRatingSummary();
const faqs = await getFaqs();

const trustStats = [
	{ value: site.license, label: 'Licensed, insured & bonded' },
	{ value: '8-5', label: 'Monday-Friday service' },
	{ value: '5 counties', label: 'Across Tampa Bay' },
	{ value: 'Upfront', label: 'Flat-rate pricing' },
];

const whyStats = [
	{ value: '5.0★', label: 'Average rating from real neighbors' },
	{ value: '1:1', label: 'A real person helps you schedule' },
	{ value: '100%', label: 'Workmanship guaranteed' },
	{ value: '$0', label: 'Surprise charges — you approve first' },
];
---

<!-- Trust strip (overlaps hero) -->
<section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
	<div
		class="relative -mt-12 grid grid-cols-2 gap-6 rounded-panel bg-white p-6 shadow-card sm:grid-cols-4 sm:p-8"
	>
		{
			trustStats.map((stat) => (
				<div class="flex flex-col items-center gap-2 text-center">
					<p class="font-heading text-xl font-extrabold text-brand-red">
						{stat.value}
					</p>
					<p class="text-sm text-ink/60">{stat.label}</p>
				</div>
			))
		}
	</div>
</section>

<!-- Services -->
<ServicesShowcase />

<!-- Why choose us -->
<section class="bg-ink-deep" aria-labelledby="why-title">
	<div class="mx-auto max-w-7xl px-4 py-24 sm:px-6 lg:px-8">
		<SectionHeading
			id="why-title"
			eyebrow="Why choose us"
			title="Neighbors first, plumbers second."
			description="We built this company on the radical idea that plumbing should be honest, tidy, and pleasant."
			tone="dark"
		/>
		<div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
			{
				whyStats.map((stat) => (
					<div class="rounded-panel border border-white/10 bg-white/5 p-8 text-center">
						<p class="font-heading text-3xl font-extrabold text-water-light">
							{stat.value}
						</p>
						<p class="mt-2 leading-relaxed text-white/65">{stat.label}</p>
					</div>
				))
			}
		</div>
	</div>
</section>

<!-- Reviews -->
<section class="bg-mist" aria-labelledby="reviews-title">
	<div class="mx-auto max-w-7xl px-4 py-24 sm:px-6 lg:px-8">
		<SectionHeading
			id="reviews-title"
			eyebrow="Reviews"
			title="Your neighbors said it best."
			description={`A ${ratingSummary.average} average across ${ratingSummary.count} ${ratingSummary.source} — here's why.`}
		/>
		<div class="mt-14 grid gap-6 md:grid-cols-3">
			{reviews.slice(0, 3).map((review) => <ReviewCard review={review} />)}
		</div>
		<div class="mt-10 text-center">
			<Button href="/reviews" variant="outline" class="text-brand-red">
				Read all reviews
			</Button>
		</div>
	</div>
</section>

<!-- Service area -->
<section
	class="mx-auto max-w-7xl px-4 py-24 sm:px-6 lg:px-8"
	aria-labelledby="area-title"
>
	<div class="grid items-center gap-12 lg:grid-cols-2">
		<div>
			<SectionHeading
				id="area-title"
				eyebrow="Service area"
				title="Proudly serving five counties."
				description="If you're in the greater Tampa Bay area, chances are we're already in your neighborhood."
				align="left"
			/>
			<ul class="mt-8 flex flex-wrap gap-3">
				{
					counties.map((county) => (
						<li class="inline-flex items-center gap-2 rounded-full border border-line bg-mist px-5 py-2.5 font-semibold text-ink/70">
							<Drop size="sm" />
							{county} County
						</li>
					))
				}
			</ul>
			<p class="mt-8 text-ink/60">
				On the edge of the map? <a
					href={site.phoneHref}
					class="font-bold text-brand-red underline-offset-4 hover:underline"
					>Call us</a
				> — we'll do our best to get to you.
			</p>
		</div>
		{
			settings.serviceAreaMapUrl ? (
				<img
					src={settings.serviceAreaMapUrl}
					alt="Service area map"
					loading="lazy"
					class="aspect-[4/3] w-full rounded-panel object-cover shadow-card"
				/>
			) : (
				<Image
					src={tampaServiceAreaImage}
					alt="Downtown Tampa skyline reflected on the waterfront at dusk"
					width={1280}
					loading="lazy"
					class="aspect-[4/3] w-full rounded-panel object-cover shadow-card"
				/>
			)
		}
	</div>
</section>

<CtaBand />

<!-- FAQ -->
<section
	class="mx-auto max-w-3xl px-4 py-24 sm:px-6"
	aria-labelledby="faq-title"
>
	<SectionHeading
		id="faq-title"
		eyebrow="FAQ"
		title="Good questions, straight answers."
	/>
	<div class="mt-12 space-y-4">
		{faqs.map((faq) => <FaqItem question={faq.question} answer={faq.answer} />)}
	</div>
</section>
