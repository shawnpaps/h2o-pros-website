---
interface Props {
  rating?: number;
  class?: string;
}

const { rating = 5, class: className = '' } = Astro.props;
---

<span class={`inline-flex items-center gap-0.5 text-star ${className}`} role="img" aria-label={`${rating} out of 5 stars`}>
  {
    Array.from({ length: 5 }).map((_, i) => (
      <svg
        width="16"
        height="16"
        viewBox="0 0 20 20"
        fill={i < rating ? 'currentColor' : 'none'}
        stroke="currentColor"
        stroke-width="1.5"
        aria-hidden="true"
      >
        <path d="M10 1.5l2.6 5.3 5.9.9-4.3 4.1 1 5.8L10 14.9l-5.2 2.7 1-5.8L1.5 7.7l5.9-.9L10 1.5z" />
      </svg>
    ))
  }
</span>
