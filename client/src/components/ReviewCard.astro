---
import Stars from './Stars.astro';
import type { Review } from '../data/reviews';

interface Props {
  review: Review;
}

const { review } = Astro.props;

const meta = [
  review.location,
  review.service,
  [review.source, review.date].filter(Boolean).join(', '),
]
  .filter(Boolean)
  .join(' · ');
---

<figure class="flex h-full flex-col rounded-card border border-line bg-white p-6 shadow-card">
  <Stars rating={review.rating} />
  <blockquote class="mt-4 flex-1 leading-relaxed text-ink/70">
    “{review.text}”
  </blockquote>
  <figcaption class="mt-6 flex items-center gap-3 border-t border-line pt-5">
    <span
      class="grid h-10 w-10 shrink-0 place-items-center rounded-full bg-fog font-heading font-bold text-water"
      aria-hidden="true"
    >
      {review.name.charAt(0)}
    </span>
    <span>
      <span class="block font-heading font-bold text-ink">{review.name}</span>
      {meta && <span class="block text-sm text-ink/50">{meta}</span>}
    </span>
  </figcaption>
</figure>
