---
/**
 * Labeled placeholder for photos that haven't been supplied yet.
 * Swap for astro:assets <Image> once real photos land in src/assets/.
 */
interface Props {
  label: string;
  class?: string;
}

const { label, class: className = '' } = Astro.props;
---

<div
  class={`grid place-items-center overflow-hidden rounded-card border border-line ${className}`}
  style="background: repeating-linear-gradient(-45deg, #F6F9FB, #F6F9FB 10px, #EEF1F4 10px, #EEF1F4 20px);"
  role="img"
  aria-label={`Placeholder: ${label}`}
>
  <span
    class="rounded-full border border-line bg-white/90 px-3 py-1.5 font-mono text-xs uppercase tracking-wider text-ink/50"
  >
    {label}
  </span>
</div>
