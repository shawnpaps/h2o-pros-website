---
/** Water-drop motif: a rotated square with one sharp corner. */
interface Props {
  color?: 'blue' | 'red' | 'white';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}

const { color = 'blue', size = 'md', class: className = '' } = Astro.props;

const colors: Record<string, string> = {
  blue: 'bg-water',
  red: 'bg-brand-red',
  white: 'bg-white',
};

const sizes: Record<string, string> = {
  sm: 'h-2.5 w-2.5',
  md: 'h-4 w-4',
  lg: 'h-6 w-6',
};
---

<span
  class={`inline-block shrink-0 rotate-45 rounded-[50%_50%_50%_0] ${colors[color]} ${sizes[size]} ${className}`}
  aria-hidden="true"></span>
