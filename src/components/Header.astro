---
import Logo from './Logo.astro';
import Button from './Button.astro';
import { site, nav } from '../data/site';

interface Props {
	/** "dark" sits transparently over the home hero; "light" is for interior pages. */
	variant?: 'dark' | 'light';
}

const { variant = 'light' } = Astro.props;
const isDark = variant === 'dark';

const wrapper = isDark
	? 'absolute inset-x-0 top-0 z-50'
	: 'sticky top-0 z-50 border-b border-line bg-white/95 backdrop-blur';
const linkColor = isDark
	? 'text-ink/80 hover:text-white'
	: 'text-ink/70 hover:text-ink';
const phoneColor = isDark ? 'text-white' : 'text-ink';
const phoneSub = isDark ? 'text-white/60' : 'text-ink/50';
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class={wrapper}>
	<div
		class="mx-auto flex max-w-7xl items-center bg-white/50 backdrop-blur-lg translate-y-4 rounded-panel justify-between gap-4 px-4 py-4 sm:px-6 lg:px-8"
	>
		<Logo />

		<nav class="hidden items-center gap-7 lg:flex" aria-label="Main">
			{
				nav.map((item) => (
					<a
						href={item.href}
						aria-current={currentPath === item.href ? 'page' : undefined}
						class={`rounded-btn py-2 font-semibold transition focus:outline-none focus-visible:ring-2 focus-visible:ring-water ${linkColor} ${currentPath === item.href ? 'text-brand-red' : ''}`}>
						{item.label}
					</a>
				))
			}
		</nav>

		<div class="hidden items-center gap-5 md:flex">
			<a
				href={site.phoneHref}
				class="rounded-btn text-right leading-none focus:outline-none focus-visible:ring-2 focus-visible:ring-water"
			>
				<span
					class={`block text-[0.65rem] font-bold uppercase tracking-[0.2em] ${phoneSub}`}
				>
					Call 24/7
				</span>
				<span
					class={`mt-1 block font-heading text-lg font-extrabold ${phoneColor}`}
				>
					{site.phone}
				</span>
			</a>
			<Button href="/contact">Book Online</Button>
		</div>

		<button
			type="button"
			data-nav-toggle
			aria-expanded="false"
			aria-controls="mobile-menu"
			class={`grid h-11 w-11 place-items-center rounded-btn lg:hidden ${isDark ? 'text-white' : 'text-ink'} focus:outline-none focus-visible:ring-2 focus-visible:ring-water`}
		>
			<span class="sr-only">Open menu</span>
			<svg
				data-icon-open
				width="24"
				height="24"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				aria-hidden="true"
			>
				<path d="M4 7h16M4 12h16M4 17h16"></path>
			</svg>
			<svg
				data-icon-close
				class="hidden"
				width="24"
				height="24"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				aria-hidden="true"
			>
				<path d="M6 6l12 12M18 6L6 18"></path>
			</svg>
		</button>
	</div>

	<div
		id="mobile-menu"
		hidden
		class={`lg:hidden ${isDark ? 'bg-ink-deep/95 backdrop-blur' : 'border-b border-line bg-white'}`}
	>
		<nav
			class="mx-auto max-w-7xl space-y-1 px-4 py-4 sm:px-6"
			aria-label="Mobile"
		>
			{
				nav.map((item) => (
					<a
						href={item.href}
						aria-current={currentPath === item.href ? 'page' : undefined}
						class={`block rounded-btn px-3 py-3 font-heading text-lg font-bold ${isDark ? 'text-white hover:bg-white/10' : 'text-ink hover:bg-mist'} focus:outline-none focus-visible:ring-2 focus-visible:ring-water`}>
						{item.label}
					</a>
				))
			}
			<div class="flex flex-col gap-3 pt-4">
				<Button href="/contact" class="w-full">Book Online</Button>
				<Button
					href={site.phoneHref}
					variant="outline"
					class={`w-full ${isDark ? 'text-white' : 'text-brand-red'}`}
				>
					Call {site.phone}
				</Button>
			</div>
		</nav>
	</div>
</header>

<script>
	const toggle = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');
	const menu = document.getElementById('mobile-menu');

	toggle?.addEventListener('click', () => {
		if (!menu) return;
		const open = menu.hidden;
		menu.hidden = !open;
		toggle.setAttribute('aria-expanded', String(open));
		toggle.querySelector('[data-icon-open]')?.classList.toggle('hidden', open);
		toggle
			.querySelector('[data-icon-close]')
			?.classList.toggle('hidden', !open);
	});
</script>
