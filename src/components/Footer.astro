---
import Logo from './Logo.astro';
import { site, hours, socials } from '../data/site';
---

<footer class="bg-ink-deep text-white">
  <div class="mx-auto grid max-w-7xl gap-10 px-4 py-14 sm:px-6 md:grid-cols-2 lg:grid-cols-4 lg:px-8">
    <div>
      <Logo tone="dark" />
      <p class="mt-5 max-w-xs leading-relaxed text-white/60">
        {site.description}
      </p>
    </div>

    <div>
      <h2 class="font-heading text-sm font-bold uppercase tracking-[0.2em] text-white/50">
        Get in touch
      </h2>
      <ul class="mt-5 space-y-3">
        <li>
          <a
            href={site.phoneHref}
            class="inline-flex min-h-[44px] items-center rounded-btn font-heading text-lg font-bold text-white hover:text-water-light focus:outline-none focus-visible:ring-2 focus-visible:ring-water"
          >
            {site.phone}
          </a>
        </li>
        <li>
          <a
            href={site.emailHref}
            class="inline-flex min-h-[44px] items-center break-all rounded-btn text-white/70 hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-water"
          >
            {site.email}
          </a>
        </li>
        <li class="text-white/60">Serving the greater Tampa Bay area</li>
      </ul>
    </div>

    <div>
      <h2 class="font-heading text-sm font-bold uppercase tracking-[0.2em] text-white/50">Hours</h2>
      <ul class="mt-5 space-y-3">
        {
          hours.map((h) => (
            <li class="flex items-baseline justify-between gap-4 text-white/70">
              <span>{h.label}</span>
              <span class={h.value === '24/7' ? 'font-bold text-water-light' : 'text-white'}>
                {h.value}
              </span>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <h2 class="font-heading text-sm font-bold uppercase tracking-[0.2em] text-white/50">
        Follow
      </h2>
      <ul class="mt-5 space-y-3">
        {
          socials.map((s) => (
            <li>
              <a
                href={s.href}
                rel="noopener"
                class="inline-flex min-h-[44px] items-center gap-3 rounded-btn text-white/70 hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-water"
              >
                <span class="inline-block h-2.5 w-2.5 rotate-45 rounded-[50%_50%_50%_0] bg-water" aria-hidden="true" />
                {s.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <div class="border-t border-white/10">
    <p class="mx-auto max-w-7xl px-4 py-6 text-center text-sm text-white/50 sm:px-6 lg:px-8">
      © {new Date().getFullYear()} Your Friendly H2O Pros Plumbing &amp; Filtration · License
      {site.license} · Insured &amp; Bonded
    </p>
  </div>
</footer>
