---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  tone?: 'light' | 'dark';
  align?: 'left' | 'center';
  class?: string;
  /** id for the h2 so a parent section can reference it via aria-labelledby */
  id?: string;
}

const {
  eyebrow,
  title,
  description,
  tone = 'light',
  align = 'center',
  class: className = '',
  id,
} = Astro.props;

const alignClasses = align === 'center' ? 'text-center mx-auto' : 'text-left';
const titleColor = tone === 'dark' ? 'text-white' : 'text-ink';
const descColor = tone === 'dark' ? 'text-white/70' : 'text-ink/60';
---

<div class={`max-w-2xl ${alignClasses} ${className}`}>
  {
    eyebrow && (
      <p class="mb-3 font-heading text-sm font-bold uppercase tracking-[0.2em] text-brand-red">
        {eyebrow}
      </p>
    )
  }
  <h2 id={id} class={`font-heading text-3xl font-extrabold tracking-tight sm:text-4xl ${titleColor}`}>
    {title}
  </h2>
  {description && <p class={`mt-4 text-lg leading-relaxed ${descColor}`}>{description}</p>}
</div>
